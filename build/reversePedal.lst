ARM GAS  /var/folders/d7/6w8d04xj28j0lv_zgsg7yqj40000gn/T//cc6x97BW.s 			page 9


  16:reversePedal.cpp **** #define DELAY_TIME (5.0f) // seconds
  17:reversePedal.cpp **** 
  18:reversePedal.cpp **** // REVERSE
  19:reversePedal.cpp **** // we will use a CIRCULAR buffer:
  20:reversePedal.cpp ****     // - think circular array, but ALSO sliding window
  21:reversePedal.cpp ****     // - there is a READ (delayed output) pointer/index and a WRITE (input) pointer/index
  22:reversePedal.cpp ****     // - both indices loop to start of buffer once end is reached
  23:reversePedal.cpp **** // Variables for REVERSE
  24:reversePedal.cpp **** 
  25:reversePedal.cpp **** 
  26:reversePedal.cpp **** size_t const revMaxLen = SAMPLE_RATE * DELAY_TIME; // max recording length (by setting to SAMPLE_RA
  27:reversePedal.cpp **** float DSY_SDRAM_BSS buffer[revMaxLen]; // the buffer -> an array of floats stored in SDRAM (64 MB) 
  28:reversePedal.cpp **** size_t inputIndex = 0; // index of input signal in buffer, where audio is being WRITTEN
  29:reversePedal.cpp **** size_t reverseIndex = 0; // keeps track of how long user has held down the reverse switch for
  30:reversePedal.cpp **** char reverseOn = 0; // needs to be mapped to physical hardware input
  31:reversePedal.cpp **** 
  32:reversePedal.cpp **** // input - signal, preferrably the effected one, not the dry one
  33:reversePedal.cpp **** // toggle - 1 for WRITING FORWARDS, -1 for READING in REVERSE, 0 for OFF
  34:reversePedal.cpp **** static float reverse(float input, int toggle){
  35:reversePedal.cpp ****     float output;    
  36:reversePedal.cpp ****     if (toggle == 1) {
  37:reversePedal.cpp ****         // WRITE FORWARDS
  38:reversePedal.cpp ****         buffer[inputIndex] = input; // WRITE input signal into reverse buffer
  39:reversePedal.cpp **** 		output = input; // leave input signal unaffected
  40:reversePedal.cpp **** 
  41:reversePedal.cpp **** 		// increment inputIndex, and wrap around if it exceeds revMaxLen
  42:reversePedal.cpp ****         inputIndex++;
  43:reversePedal.cpp ****         inputIndex %= (int)revMaxLen; // ensures circular behavior
  44:reversePedal.cpp ****     } else if (toggle == -1){
  45:reversePedal.cpp ****         // READ BACKWARDS
  46:reversePedal.cpp ****         output = buffer[inputIndex]; // READ from saved buffer into output
  47:reversePedal.cpp **** 
  48:reversePedal.cpp **** 		// decrement inputIndex, and wrap around if it goes below 0
  49:reversePedal.cpp ****         inputIndex--;
  50:reversePedal.cpp ****         inputIndex += revMaxLen; // since moving in negative direction
  51:reversePedal.cpp ****         inputIndex %= (int)revMaxLen; // ensures circular behavior
  52:reversePedal.cpp ****     }
  53:reversePedal.cpp ****     return output;
  54:reversePedal.cpp **** }
